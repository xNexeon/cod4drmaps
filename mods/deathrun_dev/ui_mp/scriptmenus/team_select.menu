#include "ui/menudef.h"

#include "ui_mp/menustyle.inc"
#include "ui/choices_setup_common.menu"

// ── Dark blue theme overrides ──────────────────────────────────────────────
#define DR_BUTTON_FORECOLOR			1 1 1 1
#define DR_BUTTON_BACKCOLOR			0.04 0.12 0.22 0.82
#define DR_BUTTON_BACKCOLOR_FOCUSED		0.10 0.28 0.52 0.90
#define DR_BUTTON_BORDERCOLOR			0.20 0.50 0.90 0.35

#include "ui_mp/dr_common.inc"

// ── Layout constants ───────────────────────────────────────────────────────
// Outer frame:  x=80  y=30  w=480  h=420   (from dr_menu_frame.inc)
// Left panel:   x=80–318   (238px wide)
// Right panel:  x=321–559  (238px wide)

#define BTN_X		96
#define BTN_W		196
#define BTN_H		20

{
	menuDef
	{
		name			"team_select"
		rect			0 0 640 480
		focuscolor		COLOR_FOCUSED
		style			WINDOW_STYLE_EMPTY
		blurWorld		7.0
		legacySplitScreenScale

		onOpen
		{
			execNow "set menuName Welcome";
		}

		onClose
		{
		}

		onEsc
		{
			close self;
		}

		// ── Frame (header bar, rank icon, player name, version text) ──────────
		#include "ui_mp/dr_menu_frame.inc"

		// ── Vertical divider ──────────────────────────────────────────────────
		itemDef
		{
			rect		319 92 1 353
			style		WINDOW_STYLE_SHADER
			background	"white"
			forecolor	0.20 0.50 0.90 0.40
			visible		1
			decoration
		}

		// ══════════════════════════════════════════════════════════════════════
		// LEFT PANEL — Buttons
		// ══════════════════════════════════════════════════════════════════════

		// --- Play ---
		itemDef
		{
			name		"btn_bg0"
			visible		1
			rect		BTN_X 100 BTN_W BTN_H
			style		WINDOW_STYLE_FILLED
			border		1
			bordercolor	0.20 0.50 0.90 0.35
			backcolor	0.04 0.12 0.22 0.82
			mouseEnter	{ setitemcolor "btn_bg0" backcolor 0.10 0.28 0.52 0.90 }
			mouseExit	{ setitemcolor "btn_bg0" backcolor 0.04 0.12 0.22 0.82 }
		}
		itemDef
		{
			visible		1
			rect		BTN_X 100 BTN_W BTN_H
			style		WINDOW_STYLE_FILLED
			forecolor	0.85 0.95 1.0 0.95
			exp			text( "@DRM_PLAY" )
			type		ITEM_TYPE_BUTTON
			textfont	UI_FONT_NORMAL
			textstyle	ITEM_TEXTSTYLE_SHADOWED
			textalign	ITEM_ALIGN_CENTER
			textscale	0.38
			textalignx	0
			textaligny	(BTN_H-2)
			mouseEnter	{ play "mouse_over"; }
			action		{ play "mouse_click"; scriptMenuResponse "autoassign"; }
		}

